<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Dark background -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#1A1B2E" />
            <size android:width="320dp" android:height="180dp" />
        </shape>
    </item>
    <!-- Accent gradient bar at bottom -->
    <item android:gravity="bottom" android:height="4dp">
        <shape android:shape="rectangle">
            <solid android:color="#7C4DFF" />
        </shape>
    </item>
</layer-list>
